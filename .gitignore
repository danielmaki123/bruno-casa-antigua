.env
token.json
client_secret.json
client_secret_*.json
credentials.json
service_account.json
*.pem
*.key
*.p12

# --- Hermes auth ---
.hermes/token.json
.hermes/client_secret.json
.hermes/memory/

# --- Datos del restaurante (información real/privada) ---
datos casa antigua/
chatteleg.txt
logseasy.txt
*.pdf

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/

# --- Base de datos locales ---
*.db
*.sqlite

# --- Sistema ---
.DS_Store
Thumbs.db
*.log
*.tmp
*.swp

# --- IDE ---
.vscode/
.idea/

# --- Herramientas internas ---
.omx/
