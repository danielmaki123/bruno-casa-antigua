# BrunoBot вЂ” Variables de Entorno
# Copiar a .env y completar con valores reales (NUNCA subir .env a git)

# в”Ђв”Ђ Telegram в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# в”Ђв”Ђ Kimi / Moonshot (LLM de Bruno) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=moonshot-v1-8k

# в”Ђв”Ђ PostgreSQL в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
DATABASE_URL=postgres://user:password@host:5435/brunobot?sslmode=disable

# в”Ђв”Ђ Grupos Telegram (IDs reales de Casa Antigua) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
GROUP_ID_INVENTARIO=-5240974489
GROUP_ID_ADMIN=-4944632677
GROUP_ID_TEAM=-5181251045

# в”Ђв”Ђ Usuarios autorizados (IDs separados por coma) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
AUTHORIZED_USERS=id1,id2,id3

# в”Ђв”Ђ Webhook HTTP в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
WEBHOOK_PORT=8080
WEBHOOK_SECRET=random_string_seguro_para_auth_interna

# в”Ђв”Ђ Umbrales в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
CIERRE_DIFF_UMBRAL=50

# в”Ђв”Ђ Google Sheets в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
GOOGLE_SHEETS_ID=your_sheet_id_here

# в”Ђв”Ђ Google OAuth (para gmail_monitor) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# token.json y credentials.json se montan como File Mounts en EasyPanel

# Variables requeridas para producciуn (monitor Gmail + inventario)
# ID de hoja administrativa (proveedores, postres)
SHEETS_ID_ADMIN=your_admin_sheet_id_here
# ID de hoja de configuraciуn (catбlogos, recetas)
SHEETS_ID_CONFIG=your_config_sheet_id_here
# ID de hoja de inventario bebidas
SHEETS_ID_BEBIDAS=your_bebidas_sheet_id_here
# Ruta local al token OAuth de Google Sheets/Gmail
SHEETS_TOKEN_PATH=/app/token.json
# Intervalo de revisiуn de Gmail en segundos
GMAIL_CHECK_INTERVAL=300
# Archivo JSON para persistir IDs de correos ya procesados
PROCESSED_EMAILS_PATH=data/processed_emails.json
# Umbral en cуrdobas para alertar diferencia POS
UMBRAL_DIFERENCIA_POS=50
# Ruta del token OAuth usada por scripts heredados
GOOGLE_TOKEN_FILE=/app/token.json
