# BrunoBot — Variables de Entorno
# Copiar a .env y completar con valores reales (NUNCA subir .env a git)

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Kimi / Moonshot (LLM de Bruno) ───────────────────────
OPENAI_API_KEY=your_kimi_api_key_here
OPENAI_BASE_URL=https://api.moonshot.ai/v1

# ── PostgreSQL (REQUERIDO para reporte_tool.py) ───────────
DATABASE_URL=postgres://user:password@host:5435/brunobot?sslmode=disable

# ── Google Sheets ─────────────────────────────────────────
SHEETS_ID_BEBIDAS=your_sheet_id_here
SHEETS_ID_ADMIN=your_sheet_id_here
SHEETS_ID_CONFIG=your_sheet_id_here

# ── Google OAuth (para gmail_monitor) ────────────────────
# token.json y credentials.json se montan como File Mounts en EasyPanel
